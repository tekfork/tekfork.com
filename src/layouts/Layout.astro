---
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: URL;
  type?: string;
}

const { title, description, image, canonicalURL, type } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="abyss">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      canonicalURL={canonicalURL}
      type={type}
    />
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-base-100 text-base-content">
    <slot />
  </body>
</html>
